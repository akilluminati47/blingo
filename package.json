{
  "name": "blingo",
  "version": "0.2.1",
  "description": "BLINGO - an infinite-map squad zombie shooter. Play as one of six immune blob cousins and save your block.",
  "author": {
    "name": "akilluminati47",
    "url": "https://github.com/akilluminati47"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "homepage": "https://blingo.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/akilluminati47/blingo.git"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "apk:sync": "node scripts/copy-web.mjs && cap sync android"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "optionalDependencies": {
    "steamworks.js": "^0.4.0"
  },
  "build": {
    "appId": "com.akilluminati47.blingo",
    "productName": "BLINGO",
    "copyright": "Copyright (c) 2026 akilluminati47 (AK & Co.). All rights reserved.",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "index.html",
      "game.js",
      "themes.js",
      "policies.js",
      "libs/**",
      "policies/**",
      "icons/**",
      "*.png",
      "*.ico",
      "site.webmanifest",
      "!dist/**",
      "!node_modules/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "BLINGO",
      "license": "LICENSE",
      "installerIcon": "build/installerIcon.ico",
      "uninstallerIcon": "build/installerIcon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallDisplayName": "BLINGO"
    },
    "portable": {
      "artifactName": "BLINGO-${version}-portable.exe"
    }
  }
}
